@page "/"
@using BancoSimulacion.Models
@using BancoSimulacion.Services
@using System.Globalization
@inject BankSimulationService SimService
@rendermode InteractiveServer

<div class="container py-4">
    <div class="card shadow-sm border-0 bg-primary text-white mb-4">
        <div class="card-body text-center">
            <h1 class="fw-bold">🏦 Simulador Bancario L&R</h1>
            <p class="mb-0">Análisis de Optimización M/M/c - Ingeniería de Sistemas</p>
        </div>
    </div>

    <div class="row g-3 mb-4 bg-white p-3 border rounded shadow-sm">
        <div class="col-md-3">
            <label class="form-label fw-bold">Llegadas (λ min):</label>
            <input type="number" step="0.1" @bind="llegadaMedia" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold">Servicio (Media min):</label>
            <input type="number" step="0.1" @bind="servicioMedia" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold">Duración (min):</label>
            <input type="number" @bind="tiempoSim" class="form-control" />
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <button class="btn btn-dark w-100 fw-bold" @onclick="Simular">EJECUTAR ANÁLISIS</button>
        </div>
    </div>

    @if (reportes.Any())
    {
        <div class="row">
            <div class="col-lg-7">
                <div class="table-responsive shadow-sm rounded">
                    <table class="table table-hover bg-white mb-0">
                        <thead class="table-dark">
                            <tr class="text-center">
                                <th>Cajeros</th>
                                <th>Espera Prom.</th>
                                <th>Ocupación</th>
                                <th>Rechazados</th>
                            </tr>
                        </thead>
                        <tbody class="text-center">
                            @foreach (var r in reportes)
                            {
                                <tr class="@(r.Cajeros == mejorId ? "table-success fw-bold" : "")">
                                    <td>@r.Cajeros</td>
                                    <td>@r.TiempoEsperaPromedio.ToString("N2") min</td>
                                    <td>@r.PorcentajeOcupacion.ToString("N1")%</td>
                                    <td class="@(r.ClientesRechazados > 0 ? "text-danger" : "")">@r.ClientesRechazados</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="alert alert-light border-primary h-100 shadow-sm">
                    <h5 class="text-primary fw-bold">🎯 Recomendación Técnica</h5>
                    <p>@analisisResultado</p>
                </div>
            </div>
        </div>

        <div class="card mt-4 shadow-sm">
            <div class="card-header bg-dark text-white">📈 Gráfico de Carga del Sistema</div>
            <div class="card-body">
                <svg width="100%" height="250" viewBox="0 0 800 250">
                    @for (int i = 0; i <= 5; i++)
                    {
                        var y = 200 - (i * 40);
                        <line x1="50" y1="@y" x2="750" y2="@y" stroke="#eee" stroke-width="1" />
                        @((MarkupString)$@"<text x=""20"" y=""{y + 5}"" font-family=""sans-serif"" font-size=""12"" fill=""#999"">{i * 2}</text>")
                    }
                    <line x1="50" y1="20" x2="50" y2="200" stroke="#333" stroke-width="2" />
                    <line x1="50" y1="200" x2="750" y2="200" stroke="#333" stroke-width="2" />

                    @{
                        var rep = reportes.First(r => r.Cajeros == mejorId);
                        double stepX = 700.0 / Math.Max(1, rep.Historico.Count - 1);
                        var puntos = string.Join(" ", rep.Historico.Select((h, i) =>
                        $"{(50 + i * stepX).ToString("F1", CultureInfo.InvariantCulture)},{(200 - h.LongitudCola * 20).ToString("F1", CultureInfo.InvariantCulture)}"));
                        <polyline points="@puntos" fill="none" stroke="#0d6efd" stroke-width="3" stroke-linejoin="round" />
                    }
                    @((MarkupString)"<text x=\"400\" y=\"240\" font-family=\"sans-serif\" font-size=\"14\" text-anchor=\"middle\">Tiempo de Simulación (Minutos)</text>")
                </svg>
            </div>
        </div>
    }
</div>

@code {
    private double llegadaMedia = 2.0;
    private double servicioMedia = 5.0;
    private int tiempoSim = 480;
    private List<ReporteEscenario> reportes = new();
    private int mejorId = 0;
    private string analisisResultado = "";

    private void Simular()
    {
        reportes.Clear();
        for (int i = 1; i <= 5; i++)
        {
            reportes.Add(SimService.EjecutarSimulacion(i, llegadaMedia, servicioMedia, tiempoSim));
        }

        var optima = reportes.OrderBy(r => r.Cajeros).FirstOrDefault(r => r.TiempoEsperaPromedio < 2.0 && r.ClientesRechazados < 5) ?? reportes.Last();
        mejorId = optima.Cajeros;
        analisisResultado = $"La mejor configuración es de {mejorId} cajeros. Esto mantiene el tiempo de espera en {optima.TiempoEsperaPromedio:N2} min con una ocupación del {optima.PorcentajeOcupacion:N1}%, optimizando el presupuesto operativo.";
    }
}